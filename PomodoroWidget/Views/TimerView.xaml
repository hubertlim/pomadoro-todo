<UserControl x:Class="PomodoroWidget.Views.TimerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PomodoroWidget.ViewModels">

    <StackPanel Margin="16,12">
        <!-- Circular Timer -->
        <Grid Width="140" Height="140" HorizontalAlignment="Center">
            <!-- Background circle -->
            <Ellipse Stroke="#10FFFFFF" StrokeThickness="6" Width="120" Height="120"/>

            <!-- Progress arc -->
            <Path StrokeThickness="6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Width="120" Height="120">
                <Path.Stroke>
                    <SolidColorBrush x:Name="ArcBrush" Color="#6366F1"/>
                </Path.Stroke>
                <Path.Data>
                    <Binding Path="ArcEndAngle" Converter="{StaticResource AngleToArc}"/>
                </Path.Data>
            </Path>

            <!-- Center text -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{Binding RemainingText}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="28" FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding PhaseText}"
                           FontSize="11" FontWeight="Medium"
                           HorizontalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentPhase}" Value="Work">
                                    <Setter Property="Foreground" Value="#6366F1"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentPhase}" Value="Rest">
                                    <Setter Property="Foreground" Value="#22C55E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- Session counter -->
        <TextBlock Text="{Binding SessionText, StringFormat='Session {0}'}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0"/>

        <!-- Controls -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <!-- Start button (visible when not running) -->
            <Button Command="{Binding StartCommand}"
                    Style="{StaticResource AccentButton}"
                    Visibility="{Binding IsRunning, Converter={StaticResource InverseBoolToVis}}"
                    Margin="0,0,6,0" Padding="14,6">
                <TextBlock Text="▶ Start"/>
            </Button>
            <!-- Pause button (visible when running) -->
            <Button Command="{Binding PauseCommand}"
                    Style="{StaticResource WidgetButton}"
                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"
                    Margin="0,0,6,0" Padding="14,6">
                <TextBlock Text="⏸ Pause"/>
            </Button>
            <Button Command="{Binding ResetCommand}"
                    Style="{StaticResource WidgetButton}" Padding="14,6">
                <TextBlock Text="⏹ Reset"/>
            </Button>
        </StackPanel>

        <!-- Settings (only when idle) -->
        <Border Visibility="{Binding IsIdle, Converter={StaticResource BoolToVis}}"
                Background="{StaticResource BgSecondaryBrush}"
                CornerRadius="8" Padding="10" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0" Text="Work" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Rest" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="Total" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" HorizontalAlignment="Center"/>

                <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding WorkMinutes, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource WidgetTextBox}" TextAlignment="Center" Margin="2" FontSize="14"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RestMinutes, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource WidgetTextBox}" TextAlignment="Center" Margin="2" FontSize="14"/>
                <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding TotalMinutes, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource WidgetTextBox}" TextAlignment="Center" Margin="2" FontSize="14"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="min" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10" HorizontalAlignment="Center"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="min" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10" HorizontalAlignment="Center"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="min" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10" HorizontalAlignment="Center"/>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
