<UserControl x:Class="PomodoroWidget.Views.TodoListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PomodoroWidget.ViewModels">

    <Grid Margin="12,8,12,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Add task bar -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Text="{Binding NewTaskText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource WidgetTextBox}"
                     Tag="Add a task..."
                     KeyDown="TaskInput_KeyDown"/>

            <ComboBox Grid.Column="1" SelectedIndex="{Binding NewTaskPriority}"
                      Margin="4,0" Width="50" VerticalAlignment="Stretch"
                      Background="{StaticResource BgInputBrush}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      FontSize="11" ToolTip="Priority">
                <ComboBoxItem Content="Low"/>
                <ComboBoxItem Content="Med"/>
                <ComboBoxItem Content="Hi"/>
            </ComboBox>

            <Button Grid.Column="2" Content="+"
                    Command="{Binding AddCommand}"
                    Style="{StaticResource AccentButton}"
                    Width="34" FontSize="16" Padding="0,4"/>
        </Grid>

        <!-- Task list -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Todos}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:TodoItemViewModel}">
                        <Border x:Name="TaskBorder" Margin="0,2" Padding="8,6"
                                CornerRadius="8"
                                Background="{StaticResource BgSecondaryBrush}"
                                BorderBrush="#08FFFFFF" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect x:Name="GlowEffect" ShadowDepth="0"
                                                  Color="#6366F1" BlurRadius="0" Opacity="0"/>
                            </Border.Effect>
                            <Border.RenderTransform>
                                <TranslateTransform/>
                            </Border.RenderTransform>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Priority dot -->
                                <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,6,0"
                                         Fill="{Binding Priority, Converter={StaticResource PriorityToColor}}"
                                         Cursor="Hand" ToolTip="Click to cycle priority"
                                         MouseLeftButtonDown="PriorityDot_Click"/>

                                <!-- Checkbox -->
                                <CheckBox Grid.Column="1" IsChecked="{Binding IsCompleted}"
                                          VerticalAlignment="Center" Margin="0,0,6,0"
                                          Command="{Binding DataContext.ToggleCompleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                          CommandParameter="{Binding}"/>

                                <!-- Text (display mode) -->
                                <TextBlock Grid.Column="2" Text="{Binding Text}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="13" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}"
                                           MouseLeftButtonDown="TaskText_DoubleClick">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                    <Setter Property="Opacity" Value="0.5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Text (edit mode) -->
                                <TextBox Grid.Column="2" Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource WidgetTextBox}" FontSize="13"
                                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                                         LostFocus="EditBox_LostFocus" KeyDown="EditBox_KeyDown"
                                         Loaded="EditBox_Loaded"/>

                                <!-- Pomodoro count -->
                                <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" Margin="4,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value=""/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PomodoroCount}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="🍅"/><Run Text="{Binding PomodoroCount, Mode=OneWay}"/>
                                </TextBlock>

                                <!-- Link to timer -->
                                <Button Grid.Column="4" Content="⏱" FontSize="14" Padding="2"
                                        Style="{StaticResource WidgetButton}" ToolTip="Link to timer"
                                        Command="{Binding DataContext.LinkToTimerCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>

                                <!-- Delete -->
                                <Button Grid.Column="5" Content="✕" FontSize="11" Padding="2"
                                        Style="{StaticResource WidgetButton}" Opacity="0.5"
                                        ToolTip="Delete"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </Border>

                        <!-- Glow animation trigger -->
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="GlowStoryboard">
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation
                                                Storyboard.TargetName="GlowEffect"
                                                Storyboard.TargetProperty="Opacity"
                                                From="0.3" To="0.85" Duration="0:0:1"/>
                                            <DoubleAnimation
                                                Storyboard.TargetName="GlowEffect"
                                                Storyboard.TargetProperty="BlurRadius"
                                                From="8" To="22" Duration="0:0:1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="GlowStoryboard"/>
                                </DataTrigger.ExitActions>
                                <Setter TargetName="TaskBorder" Property="BorderBrush" Value="#606366F1"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Clear completed -->
        <Button Grid.Row="2" Content="Clear completed"
                Command="{Binding ClearCompletedCommand}"
                Style="{StaticResource WidgetButton}"
                Foreground="{StaticResource TextSecondaryBrush}"
                FontSize="11" HorizontalAlignment="Right" Margin="0,6,0,0"/>
    </Grid>
</UserControl>
