<UserControl x:Class="PomodoroWidget.Views.MorningReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PomodoroWidget.ViewModels">

    <Grid Margin="14,8,14,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelCard}" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Review carry-over"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="18"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding ReviewSummaryText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ReviewTasks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:TodoItemViewModel}">
                        <Border Style="{StaticResource PanelCard}" Padding="10" Margin="0,0,0,6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Ellipse Grid.RowSpan="2"
                                         Width="8" Height="8"
                                         Margin="0,5,8,0"
                                         VerticalAlignment="Top"
                                         Fill="{Binding Priority, Converter={StaticResource PriorityToColor}}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Text}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,7,0,0">
                                    <TextBlock Text="{Binding StatusText}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="10"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <Button Content="Today"
                                            Command="{Binding DataContext.KeepReviewTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource AccentButton}"
                                            FontSize="11"
                                            Padding="8,3"
                                            Margin="0,0,5,0"/>
                                    <Button Content="Tomorrow"
                                            Command="{Binding DataContext.DeferReviewTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource WidgetButton}"
                                            FontSize="11"
                                            Padding="8,3"
                                            Margin="0,0,5,0"/>
                                    <Button Content="Drop"
                                            Command="{Binding DataContext.DropReviewTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource WidgetButton}"
                                            FontSize="11"
                                            Padding="8,3"
                                            Opacity="0.65"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <WrapPanel Grid.Row="2" Margin="0,8,0,0" HorizontalAlignment="Right">
            <Button Content="Keep all today"
                    Command="{Binding KeepAllReviewTasksCommand}"
                    Style="{StaticResource AccentButton}"
                    FontSize="11"
                    Padding="10,6"
                    Margin="0,0,6,0"/>
            <Button Content="Defer all"
                    Command="{Binding DeferAllReviewTasksCommand}"
                    Style="{StaticResource WidgetButton}"
                    FontSize="11"
                    Padding="10,6"/>
        </WrapPanel>
    </Grid>
</UserControl>
