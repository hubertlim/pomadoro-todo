<Window x:Class="PomodoroWidget.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PomodoroWidget.ViewModels"
        xmlns:views="clr-namespace:PomodoroWidget.Views"
        Title="Pomodoro Widget"
        Width="380" Height="660"
        MinWidth="320" MinHeight="240"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Border Background="{StaticResource BgPrimaryBrush}"
            CornerRadius="8"
            BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="10" Opacity="0.32" Color="Black"/>
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform Y="0"/>
        </Border.RenderTransform>
        <Border.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="0" To="1" Duration="0:0:0.16"/>
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                                         From="6" To="0" Duration="0:0:0.16">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Pomodoro"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="Plan, focus, return tomorrow"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="10" Margin="0,1,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Command="{Binding ShowPlanCommand}"
                            Style="{StaticResource WidgetButton}"
                            Height="28" Padding="7,0"
                            FontSize="11" ToolTip="Plan today">
                        <TextBlock Text="Plan"/>
                    </Button>

                    <Button Grid.Column="2"
                            Command="{Binding BeginFocusCommand}"
                            Style="{StaticResource WidgetButton}"
                            Height="28" Padding="7,0"
                            FontSize="11" ToolTip="Focus current task">
                        <TextBlock Text="Focus"/>
                    </Button>

                    <Button Grid.Column="3"
                            Command="{Binding ToggleDashboardCommand}"
                            Style="{StaticResource WidgetButton}"
                            Height="28" Padding="7,0"
                            FontSize="11" ToolTip="Progress dashboard">
                        <TextBlock Text="Stats"/>
                    </Button>

                    <Button Grid.Column="4"
                            Command="{Binding BeginShutdownCommand}"
                            Style="{StaticResource WidgetButton}"
                            Height="28" Padding="7,0"
                            FontSize="11" ToolTip="Shutdown today">
                        <TextBlock Text="End"/>
                    </Button>

                    <Button Grid.Column="5"
                            Style="{StaticResource WidgetButton}"
                            Width="28" Height="28" Padding="0"
                            Click="CloseButton_Click" ToolTip="Close">
                        <TextBlock Text="x" FontSize="12" Opacity="0.6"/>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="0" BorderBrush="#10FFFFFF" BorderThickness="0,0,0,1"
                    VerticalAlignment="Bottom"/>

            <views:TimerView Grid.Row="1" DataContext="{Binding Timer}"/>

            <Grid Grid.Row="2"
                  Visibility="{Binding DataContext.IsExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                <views:MorningReviewView DataContext="{Binding Todo}"
                                         Visibility="{Binding DataContext.IsReviewVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                <views:TodoListView DataContext="{Binding Todo}"
                                    Visibility="{Binding DataContext.IsPlanVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                <views:FocusView DataContext="{Binding}"
                                 Visibility="{Binding IsFocusVisible, Converter={StaticResource BoolToVis}}"/>
                <views:DashboardView DataContext="{Binding Analytics}"
                                     Visibility="{Binding DataContext.IsDashboardVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                <views:ShutdownView DataContext="{Binding}"
                                    Visibility="{Binding IsShutdownVisible, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
