<Window x:Class="PomodoroWidget.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PomodoroWidget.ViewModels"
        xmlns:views="clr-namespace:PomodoroWidget.Views"
        Title="Pomodoro Widget"
        Width="320" Height="520"
        MinWidth="292" MinHeight="360"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Border Background="{StaticResource ConsoleShellBrush}"
            CornerRadius="8"
            BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="10" Opacity="0.32" Color="Black"/>
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform Y="0"/>
        </Border.RenderTransform>
        <Border.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="0" To="1" Duration="0:0:0.16"/>
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                                         From="6" To="0" Duration="0:0:0.16">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Padding="10,9,10,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource ConsolePanel}" Padding="9,7">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="58"/>
                            </Grid.ColumnDefinitions>

                            <Ellipse Width="7" Height="7"
                                     Fill="{StaticResource ConsoleLineBrush}"
                                     VerticalAlignment="Top"
                                     Margin="0,4,8,0"/>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="POMODORO OS"
                                           Foreground="{StaticResource ConsoleLineBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding WorkflowNudgeText}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,1,6,0"/>
                            </StackPanel>

                            <Canvas Grid.Column="2"
                                    Width="52"
                                    Height="22"
                                    VerticalAlignment="Center"
                                    ClipToBounds="True">
                                <Path Stroke="{StaticResource ConsoleLineBrush}"
                                      StrokeThickness="1.4"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Opacity="0.72"
                                      Data="M 0 11 L 6 11 L 9 5 L 13 17 L 17 8 L 21 14 L 26 11 L 31 11 L 35 6 L 39 16 L 43 10 L 48 11">
                                    <Path.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0.35" To="0.95" Duration="0:0:1.1"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Path.Triggers>
                                </Path>
                            </Canvas>
                        </Grid>
                    </Border>

                    <Button Grid.Column="1"
                            Style="{StaticResource WidgetButton}"
                            Width="26" Height="26" Padding="0"
                            Margin="7,0,0,0"
                            Click="CloseButton_Click" ToolTip="Close">
                        <TextBlock Text="x" FontSize="11" Opacity="0.62"/>
                    </Button>
                </Grid>
            </Border>

            <views:TimerView Grid.Row="1" DataContext="{Binding Timer}"/>

            <Border Grid.Row="2"
                    Style="{StaticResource ConsolePanel}"
                    Padding="7"
                    Margin="10,0,10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Plan"
                            Command="{Binding ShowPlanCommand}"
                            Style="{StaticResource ModeButton}"
                            Margin="0,0,4,0"
                            ToolTip="Plan today"/>
                    <Button Grid.Column="1"
                            Content="Focus"
                            Command="{Binding BeginFocusCommand}"
                            Style="{StaticResource ModeButton}"
                            Margin="0,0,4,0"
                            ToolTip="Focus current task"/>
                    <Button Grid.Column="2"
                            Content="Stats"
                            Command="{Binding ToggleDashboardCommand}"
                            Style="{StaticResource ModeButton}"
                            Margin="0,0,4,0"
                            ToolTip="Progress dashboard"/>
                    <Button Grid.Column="3"
                            Content="End"
                            Command="{Binding BeginShutdownCommand}"
                            Style="{StaticResource ModeButton}"
                            ToolTip="Shutdown today"/>
                </Grid>
            </Border>

            <Grid Grid.Row="3"
                  Visibility="{Binding DataContext.IsExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                <views:MorningReviewView DataContext="{Binding Todo}"
                                         Visibility="{Binding DataContext.IsReviewVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                <views:TodoListView DataContext="{Binding Todo}"
                                    Visibility="{Binding DataContext.IsPlanVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                <views:FocusView DataContext="{Binding}"
                                 Visibility="{Binding IsFocusVisible, Converter={StaticResource BoolToVis}}"/>
                <views:DashboardView DataContext="{Binding Analytics}"
                                     Visibility="{Binding DataContext.IsDashboardVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                <views:ShutdownView DataContext="{Binding}"
                                    Visibility="{Binding IsShutdownVisible, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
